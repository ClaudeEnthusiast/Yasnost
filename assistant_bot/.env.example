# Telegram
BOT_TOKEN=your_bot_token_from_BotFather
TELEGRAM_USER_ID=your_numeric_id  # узнать через @userinfobot

# PostgreSQL (unix socket, peer auth)
DB_HOST=/var/run/postgresql
DB_PORT=5432
DB_NAME=yasnost
DB_USER=yasnost
DB_PASSWORD=

# AI (опциональные — без них базовые функции всё равно работают)
ANTHROPIC_API_KEY=sk-ant-...   # для документов, голосового роутинга, отчётов
OPENAI_API_KEY=sk-...          # для транскрипции голоса (Whisper)

# Расписание (опционально)
TIMEZONE=Europe/Moscow
DAILY_BRIEF_HOUR=9             # дейли-бриф в 09:00
WEEKLY_REPORT_DAY=0            # 0=воскресенье
WEEKLY_REPORT_HOUR=20          # в 20:00
